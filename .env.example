# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- Database ---------------------------------------------------------------
# TiDB Cloud (MySQL-compatible) — used in deployment. TLS is enabled in code
# via the certifi CA bundle, so no extra query params are needed here.
#   mysql+pymysql://<user>:<password>@<host>:4000/<database>
DATABASE_URL=mysql+pymysql://xxxxxxxxxxx.root:YOUR_PASSWORD@gateway01.<region>.prod.aws.tidbcloud.com:4000/maintenance_triage

# Local Postgres alternative (comment the line above and use this instead):
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/maintenance_triage

# --- Claude / Anthropic -----------------------------------------------------
# Optional. Without it, triage falls back to a transparent keyword heuristic so
# the app still runs end-to-end. Set it to use the real Claude agent.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# --- Wiring -----------------------------------------------------------------
# Where the Streamlit frontend reaches the FastAPI backend. Locally this is
# localhost; in the cloud the frontend uses BACKEND_URL from Streamlit secrets
# (pointing at the Render backend) instead of this file.
BACKEND_URL=http://localhost:8000

# --- Seeding (deployment convenience) ---------------------------------------
# When "true", the backend seeds sample work orders on first startup if the
# table is empty. Handy on Render where there's no shell. Leave unset locally.
# SEED_ON_START=true
