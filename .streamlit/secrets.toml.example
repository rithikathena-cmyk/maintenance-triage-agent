# Streamlit secrets for the single-process (Streamlit Community Cloud) deploy.
#
# On Streamlit Cloud: paste this into the app's Settings → Secrets box.
# Locally (optional): copy to `.streamlit/secrets.toml` — it's gitignored.
#
# The app bridges these into the environment so the in-process backend and the
# MCP servers can read them.

# TiDB Cloud (MySQL-compatible). TLS is handled in code via certifi.
DATABASE_URL = "mysql+pymysql://xxxxxxxxxxx.root:YOUR_PASSWORD@gateway01.<region>.prod.aws.tidbcloud.com:4000/maintenance_triage"

# Your Anthropic key (rotate before deploying). Without it, triage falls back to
# a transparent keyword heuristic so the app still runs.
ANTHROPIC_API_KEY = "sk-ant-..."
CLAUDE_MODEL = "claude-opus-4-8"

# Seed sample work orders on first boot if the DB is empty (safe to leave on).
SEED_ON_START = "true"
