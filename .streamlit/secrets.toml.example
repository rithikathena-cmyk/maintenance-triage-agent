# Streamlit secrets for the single-process (Streamlit Community Cloud) deploy.
#
# On Streamlit Cloud: paste this into the app's Settings → Secrets box.
# Locally (optional): copy to `.streamlit/secrets.toml` — it's gitignored.

# --- Database ---------------------------------------------------------------
# OPTIONAL. Leave unset to use the local SQLite file (ephemeral on Streamlit
# Cloud — resets on reboot). For PERSISTENT data, point at a hosted MySQL such
# as Aiven (TLS is handled in code via certifi):
# DATABASE_URL = "mysql+pymysql://<user>:<password>@<host>:<port>/maintenance_triage"

# --- Claude / Anthropic -----------------------------------------------------
# Optional. Without it, triage falls back to a transparent keyword heuristic.
ANTHROPIC_API_KEY = "sk-ant-..."
CLAUDE_MODEL = "claude-opus-4-8"

# Seed sample work orders on first run (also auto-seeds when the DB is empty).
SEED_ON_START = "true"
